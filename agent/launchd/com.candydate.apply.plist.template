<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.candydate.apply</string>

    <!-- Pass C+D (--batch-apply) : 14:00 KST -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__REPO_DIR__/agent/launchd/run_pass_d.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>14</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/com.candydate.agent.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/com.candydate.agent.log</string>

    <key>WorkingDirectory</key>
    <string>__REPO_DIR__/agent</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
